{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "functions": {
    "api/*.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/dropoff-leads",
      "schedule": "30 2 * * *"
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/index.html" }
  ]
}
